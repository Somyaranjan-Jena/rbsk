# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Environment variables (never commit secrets) ─────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js

# ─── Build output ─────────────────────────────────────────────────────────────
/build
/dist
*.tsbuildinfo

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ─── Vite ─────────────────────────────────────────────────────────────────────
.vite/

# ─── Firebase ─────────────────────────────────────────────────────────────────
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ─── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
